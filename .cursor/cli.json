{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(engine/**)",
      "Write(app/**)",
      "Write(mdc/**)",
      "Write(tools/**)",
      "Write(deploy/**)",
      "Write(scripts/agents/**)",
      "Shell(cmake)",
      "Shell(ctest)",
      "Shell(npm)",
      "Shell(node)",
      "Shell(cargo)",
      "Shell(git)",
      "Shell(jq)",
      "Shell(docker compose)"
    ],
    "deny": [
      "Shell(rm)",
      "Read(.env*)",
      "Write(.env*)",
      "Write(**/*.key)",
      "Write(**/*.pem)"
    ]
  }
}
